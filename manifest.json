{
  "manifest_version": 3,
  "name": "Text Clipper",
  "version": "1.1.0",
  "description": "Highlight text on any page, right-click to save it or get an AI-generated job application answer.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Text Clipper"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
