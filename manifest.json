{
  "manifest_version": 3,
  "name": "Clyde Go",
  "version": "1.2.2",
  "description": "Automate your job search with Tailored Cover Letters, Resumes, AI generated answers, and 1-click Autofill.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "offscreen",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://clydeai.live/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Clyde Go",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "content/portal-handlers/smartrecruiters-inject.js",
        "icons/icon48.png",
        "icons/icon128.png",
        "icons/sidebar_ghost_icon.svg",
        "popup.html",
        "popup.js",
        "icons/popup_ui_header.svg",
        "icons/clyde_apply.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.myworkdayjobs.com/*",
        "*://*.smartrecruiters.com/*",
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://jobs.lever.co/*",
        "*://*.ashbyhq.com/*",
        "*://*.icims.com/*",
        "*://*.taleo.net/*",
        "*://*.linkedin.com/jobs/*",
        "*://*.successfactors.com/*",
        "*://*.successfactors.eu/*",
        "*://*.oraclecloud.com/*",
        "*://*.workable.com/*",
        "*://*.bamboohr.com/*",
        "*://*.bamboohr.co.uk/*"
      ],
      "all_frames": true,
      "js": [
        "lib/escape.js",
        "content/portal-handlers/index.js",
        "content/portal-handlers/ashby.js",
        "content/portal-handlers/greenhouse.js",
        "content/portal-handlers/lever.js",
        "content/portal-handlers/workday.js",
        "content/portal-handlers/linkedin.js",
        "content/portal-handlers/smartrecruiters.js",
        "content/portal-handlers/icims.js",
        "content/portal-handlers/taleo.js",
        "content/portal-handlers/successfactors.js",
        "content/portal-handlers/oracle-orc.js",
        "content/portal-handlers/workable.js",
        "content/portal-handlers/bamboohr.js",
        "content/portal-handlers/generic.js",
        "content/form-detector.js",
        "content/form-filler.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}